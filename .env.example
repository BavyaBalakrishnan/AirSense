# Copy to .env and fill in. NEVER commit the real .env.

# Required — Gemini for the planner LLM.
# gemini-2.5-flash-lite has the biggest free-tier daily cap (~1000/day).
# DO NOT use gemini-2.5-flash — only 20/day on free tier.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional but recommended — enables CPCB station data via AQICN.
# Get a free token: https://aqicn.org/data-platform/token/
AQICN_TOKEN=

# Optional but recommended — enables NASA FIRMS satellite-fire detection.
# Get a free MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=
